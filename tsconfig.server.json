{
  "compilerOptions": {
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "src/*": ["./src/*"],
      "server/*": ["./server/*"]
    },
    "rootDir": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "types": ["node"]
  },
  "include": ["server/**/*.ts"]
}
